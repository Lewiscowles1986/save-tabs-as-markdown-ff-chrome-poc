{
  "manifest_version": 3,
  "name": "Save Tab URLs",
  "version": "0.2.0",
  "description": "Save open tabs to markdown",
  "author": "LewisCowles <codesign2@icloud.com>",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon.png"
  },
  "homepage_url": "https://lewiscowles.co.uk",
  "permissions": [
    "activeTab",
    "contextMenus",
    "tabs"
  ],
  "action": {
    "default_icon": "icons/icon.png",
    "default_title": "Save URLs",
    "default_popup": "popup/window.html"
  }
}
